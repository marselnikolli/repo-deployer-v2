{
  "manifest_version": 2,
  "name": "Repo Deployer — Quick Import",
  "version": "1.0.0",
  "description": "Import GitHub repositories and bookmarks into your Repo Deployer instance.",
  "sidebar_action": {
    "default_title": "Repo Deployer",
    "default_panel": "popup.html"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "bookmarks",
    "downloads",
    "https://github.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "scripts": ["background.firefox.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "repo-deployer@extension",
      "strict_min_version": "109.0"
    }
  }
}
