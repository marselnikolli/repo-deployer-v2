{
  "manifest_version": 3,
  "name": "Repo Deployer — Quick Import",
  "version": "1.0.0",
  "description": "Import GitHub repositories and bookmarks into your Repo Deployer instance.",
  "action": {
    "default_title": "Open Repo Deployer"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "bookmarks",
    "downloads",
    "sidePanel"
  ],
  "host_permissions": [
    "https://github.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
